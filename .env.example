# Voice Team - Environment Configuration
# Copy this file to .env and fill in your values

# Server bind address (0.0.0.0 for Render/cloud, 127.0.0.1 for local dev)
BIND_ADDR=0.0.0.0

# SBC Domain
SBC_DOMAIN=your-sbc-domain.com

# SBC WebSocket Address (comma-separated for multiple)
SBC_ADDRESSES=wss://your-sbc-domain.com:443

# SIP Call User
SIP_USER=1000

# SIP Caller ID
SIP_CALLER=1000

# SIP Caller Display Name
SIP_CALLER_DN=Voice Team

# Call type: audio, video, or user_control
CALL_TYPE=user_control

# Optional STUN/TURN servers (JSON array)
# ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]