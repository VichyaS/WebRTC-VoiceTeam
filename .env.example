# ═══════════════════════════════════════════════════════════
# Voice Team — Click to Call  Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file as .env and fill in your values.
# This file is for LOCAL DEVELOPMENT only.
# On Render/AWS/GCP, set these via Environment Variables directly.
# ═══════════════════════════════════════════════════════════


# ─── Server Settings ──────────────────────────────────────
PORT=3000
BIND_ADDR=127.0.0.1


# ─── Demo / Local Users ──────────────────────────────────
# Demo accounts defined in conf/ad_users.json are always available.
# To DISABLE demo users, set this to 'false' (requires LDAP or OIDC).
# C2C_DEMO_ENABLED=true


# ═══════════════════════════════════════════════════════════
# 1️⃣ LDAP / Active Directory Authentication
#    ใช้เมื่อมี AD/LDAP Server จริง (JumpCloud, Azure AD via LDAP, etc.)
# ═══════════════════════════════════════════════════════════

# LDAP_SERVER_URL — URL ของ LDAP server
#   ตัวอย่าง: ldap://sbc-ad.yourcompany.com:389
#   ตัวอย่าง: ldaps://sbc-ad.yourcompany.com:636
# LDAP_URL=ldap://localhost:389

# LDAP_BASE_DN — Base distinguished name สำหรับค้นหาผู้ใช้
#   ตัวอย่าง: dc=yourcompany,dc=com
# LDAP_BASE_DN=dc=example,dc=com

# LDAP_BIND_DN — Service account ที่ใช้ค้นหาผู้ใช้ (ถ้าต้องการ)
#   ถ้าเว้นว่าง ระบบจะลอง bind ด้วย user โดยตรง
# LDAP_BIND_DN=cn=admin,dc=example,dc=com
# LDAP_BIND_PASSWORD=your-admin-password

# LDAP_SEARCH_FILTER — กรองค้นหาผู้ใช้ ({{username}} = ค่าที่ user ป้อน)
#   ค่าเริ่มต้น: (uid={{username}})
#   สำหรับ AD: (&(objectClass=user)(sAMAccountName={{username}}))
# LDAP_SEARCH_FILTER=(uid={{username}})

# ─── LDAP → Config.js Attribute Mapping ──────────────────
# กำหนดว่า attribute ใดใน AD จะ map ไปยังค่า config.js
#   ค่าเริ่มต้น (ตามลำดับ):
#     domain    ← sbcDomain    ใน AD
#     addresses ← sbcAddresses ใน AD
#     call      ← sipCall      ใน AD
#     caller    ← sipCaller    ใน AD
#     callerDN  ← displayName  ใน AD
# LDAP_ATTR_DOMAIN=sbcDomain
# LDAP_ATTR_ADDRESSES=sbcAddresses
# LDAP_ATTR_CALL=sipCall
# LDAP_ATTR_CALLER=sipCaller
# LDAP_ATTR_CALLER_DN=displayName


# ═══════════════════════════════════════════════════════════
# 2️⃣ Okta OIDC (OpenID Connect) Authentication
#    ใช้ Okta Developer Edition — ฟรี 500 users
# ═══════════════════════════════════════════════════════════

# OIDC_ISSUER — Okta Domain URL
#   ไปที่ Okta Admin Console → Dashboard → ดึง Org URL
#   ตัวอย่าง: https://dev-12345678.okta.com
#   ตัวอย่าง: https://yourcompany.okta.com
# OIDC_ISSUER=https://dev-XXXXXX.okta.com

# OIDC_CLIENT_ID — จาก Okta Application settings
#   ไปที่ Applications → [Your App] → Client ID
# OIDC_CLIENT_ID=0oaXXXXXXXXXXXXXXXXX

# OIDC_CLIENT_SECRET — จาก Okta Application settings
#   ไปที่ Applications → [Your App] → Client Secret
# OIDC_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OIDC_CALLBACK_URL — URL ที่ Okta redirect กลับมาหลัง login
#   ต้องตรงกับ "Login redirect URIs" ใน Okta App settings
# OIDC_CALLBACK_URL=http://localhost:3000/api/auth/callback

# ─── Okta Endpoints (ใช้ค่าเริ่มต้นสำหรับ Okta) ───────────
# ถ้าเปลี่ยนเป็น provider อื่น (Auth0, Azure AD) ให้เปลี่ยน endpoints
# OIDC_AUTHZ_ENDPOINT=/oauth2/v1/authorize
# OIDC_TOKEN_ENDPOINT=/oauth2/v1/token
# OIDC_USERINFO_ENDPOINT=/oauth2/v1/userinfo
# OIDC_JWKS_ENDPOINT=/oauth2/v1/keys
# OIDC_SCOPE=openid profile email

# ─── Okta → Config.js Attribute Mapping ──────────────────
# ชื่อ attributes ใน Okta User Profile ที่ map ไป config
# ค่าเหล่านี้ต้องตรงกับที่สร้างใน Okta Profile Editor
# OIDC_ATTR_DOMAIN=sbcDomain
# OIDC_ATTR_ADDRESSES=sbcAddresses
# OIDC_ATTR_CALL=sipCall
# OIDC_ATTR_CALLER=sipCaller
# OIDC_ATTR_CALLER_DN=displayName


# ═══════════════════════════════════════════════════════════
# 3️⃣ Admin Configuration (Encrypted SSO Config Manager)
#    ตั้งค่า ADMIN_CONFIG_PASSWORD เพื่อเปิดใช้งาน UI
#    สำหรับจัดการ SSO credentials แบบเข้ารหัส
#    เก็บเป็น AES-256-GCM ที่ conf/sso_config.enc
# ═══════════════════════════════════════════════════════════

# ADMIN_CONFIG_PASSWORD — รหัสผ่านสำหรับเข้าหน้า Admin UI
#   หน้า Admin อยู่ที่ /html/admin.html
#   ใช้สำหรับตั้งค่า OIDC/LDAP ผ่าน UI แทนการแก้ .env
#   ข้อมูลถูกเข้ารหัส AES-256-GCM ด้วย PBKDF2 key derivation
#   ⚠️ ตั้งค่าที่แข็งแรง! อย่างน้อย 16 ตัวอักษร
# ADMIN_CONFIG_PASSWORD=your-strong-admin-password-here


# ═══════════════════════════════════════════════════════════
# ⚠️ หมายเหตุ: ระบบรองรับ LDAP และ OIDC พร้อมกัน
#    ถ้าตั้งทั้ง LDAP_URL และ OIDC_ISSUER:
#      - login form (username/password) → LDAP
#      - "Sign in with Okta/SSO" button → OIDC
#    ถ้าไม่ได้ตั้งค่าอะไรเลย → ใช้ demo users (ad_users.json)
# ═══════════════════════════════════════════════════════════